# ---- Convex (apps/convex/.env.local) ----
# Dev (local) values are written automatically by `npx convex dev`.
# PRODUCTION (deployed):
CONVEX_DEPLOYMENT=shocking-warbler-536
CONVEX_URL=https://shocking-warbler-536.convex.cloud
CONVEX_SITE_URL=https://shocking-warbler-536.convex.site

# Live platform OAuth / API keys (leave blank for mock-only mode)
KLAVIYO_CLIENT_ID=
KLAVIYO_CLIENT_SECRET=
KLAVIYO_API_KEY=
ATTENTIVE_CLIENT_ID=
ATTENTIVE_CLIENT_SECRET=

# Alert delivery (optional)
ALERT_WEBHOOK=
ALERT_EMAIL_URL=
ALERT_EMAIL_TO=

# Magic-link email gateway (optional; link is logged if unset)
MAGIC_LINK_EMAIL_URL=

# Live benchmark feed (optional; illustrative defaults if unset)
BENCHMARK_FEED_URL=

HIRO_WEB_URL=https://your-app-domain.com

# ---- Web (apps/web/.env.local) ----
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site
NEXT_PUBLIC_APP_URL=https://your-app-domain.com
