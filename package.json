{
  "name": "hiro-analytics",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.16.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "deploy:convex": "npm run deploy --workspace=@hiro/convex",
    "deploy:web": "npm run deploy --workspace=@hiro/web"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  }
}
